include README.rst
include CHANGES.rst
include LICENSE
include pyproject.toml
include noxfile.py
exclude .gitmodules

graft docs

graft examples

graft src
prune src/libtreesitter/tree-sitter.c

graft tests

global-exclude \#* \#*/**
global-exclude .build .build/** .build.* .build.*/**
global-exclude *.py[cod] __pycache__ .mypy_cache
